# --- Devin API ---
# Service-user key (cog_...). Get from your Devin org settings.
DEVIN_API_KEY=cog_xxx
DEVIN_ORG_ID=org-d993acc3f9fd4902ba71433ecf603ca6
DEVIN_BASE_URL=https://api.devin.ai/v3
# normal | fast | lite | ultra | fusion
DEVIN_MODE=normal
# Safety cap on ACUs per session (Devin credits). Keep low for demos.
DEVIN_MAX_ACU=10

# --- Target repository (your Superset fork) ---
TARGET_REPO=louisgrimaldi/superset

# --- GitHub ---
# Token used to comment PR links back on issues + poll for labeled issues.
# Needs 'repo' scope. In a demo you can reuse your gh CLI token.
GITHUB_TOKEN=ghp_xxx
# Secret shared with the GitHub webhook (HMAC SHA-256). Any random string.
GITHUB_WEBHOOK_SECRET=change-me-to-a-random-string
# Only issues carrying this label are remediated.
TRIGGER_LABEL=devin

# --- Service behaviour ---
# Poll the repo for labeled-but-undispatched issues every N seconds (0 disables).
POLL_INTERVAL_SECONDS=60
# Poll Devin session status every N seconds.
RECONCILE_INTERVAL_SECONDS=20
# SQLite state file.
DB_PATH=/data/state.db
# Set to 1 to allow dispatching real Devin sessions. When 0, dispatch is
# recorded but no session is created (safe dry-run for wiring up the demo).
DISPATCH_ENABLED=1

# --- Console behaviour (overridable live on the Settings tab) ---
# How Devin is triggered to remediate: on_creation | on_comment
REMEDIATION_TRIGGER=on_creation
# The comment command that triggers remediation in on_comment mode.
TRIGGER_COMMAND=/devin
# Automatic scan schedule: manual | hourly | daily | weekly | monthly
SCAN_SCHEDULE=manual
# Max findings a scan returns.
SCAN_MAX_FINDINGS=15
# Base URL the service calls to fire a webhook at itself when a finding is
# filed (keeps the trigger path identical to production). Inside Docker this
# stays localhost because the app calls its own port.
SELF_BASE_URL=http://127.0.0.1:8000
